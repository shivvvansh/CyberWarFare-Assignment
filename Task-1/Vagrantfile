# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  # Ubuntu 22.04 LTS base box
  config.vm.box = "ubuntu/jammy64"
  config.vm.hostname = "devops-server"

  # Create a private network with a static IP
  config.vm.network "private_network", ip: "192.168.56.10", type: "dhcp", auto_config: true

  # Disable the default synced folder (optional, avoids issues)
  config.vm.synced_folder ".", "/vagrant", disabled: false

  # Forward port 8000 for Docker container access
  config.vm.network "forwarded_port", guest: 8000, host: 8000

  # Forward SSH explicitly for reliable access
  config.vm.network "forwarded_port", guest: 22, host: 2222, id: "ssh", auto_correct: true

  # VirtualBox provider settings
  config.vm.provider "virtualbox" do |vb|
    vb.name   = "DevOps-Server"
    vb.memory = "2048"
    vb.cpus   = 2
  end

  # Provisioning: update system and configure SSH
  config.vm.provision "shell", inline: <<-SHELL
    # Update system packages
    apt-get update -y && apt-get upgrade -y

    # Ensure SSH is installed and running
    apt-get install -y openssh-server
    systemctl enable ssh
    systemctl start ssh

    # Configure SSH for key-based authentication only
    sed -i 's/^#\\?PasswordAuthentication yes/PasswordAuthentication no/' /etc/ssh/sshd_config
    sed -i 's/^#\\?PubkeyAuthentication no/PubkeyAuthentication yes/' /etc/ssh/sshd_config
    sed -i 's/^#\\?PubkeyAuthentication yes/PubkeyAuthentication yes/' /etc/ssh/sshd_config
    sed -i 's/^#\\?ChallengeResponseAuthentication yes/ChallengeResponseAuthentication no/' /etc/ssh/sshd_config

    # Restart SSH to apply changes
    systemctl restart ssh

    echo "✅ SSH configured for key-based authentication only."
  SHELL
end
